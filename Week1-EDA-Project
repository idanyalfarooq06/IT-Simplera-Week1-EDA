    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. LOAD DATASET (Excel format from your direct path)\n",
    "file_path = r'C:\\Users\\MuhammadDanyalFarooq\\Downloads\\online_retail_II.xlsx'\n",
    "print(\"Loading data... Please wait (this can take up to 30 seconds for a 44MB file)...\")\n",
    "df = pd.read_excel(file_path)\n",
    "\n",
    "# 2. BASIC INFORMATION DISPLAY\n",
    "print(\"\\n--- 1. Dataset Shape ---\")\n",
    "print(f\"Rows: {df.shape[0]}, Columns: {df.shape[1]}\")\n",
    "\n",
    "print(\"\\n--- 2. Columns & Data Types ---\")\n",
    "df.info()\n",
    "\n",
    "print(\"\\n--- 3. First 5 Rows ---\")\n",
    "print(df.head())\n",
    "\n",
    "# 3. MISSING VALUES & DUPLICATES (Observation Only)\n",
    "print(\"\\n--- 4. Missing Values Count Per Column ---\")\n",
    "print(df.isnull().sum())\n",
    "\n",
    "print(f\"\\nTotal Duplicate Rows Found: {df.duplicated().sum()}\")\n",
    "\n",
    "# 4. TOP 10 BEST SELLING PRODUCTS\n",
    "# Create Revenue Column (Quantity * Price)\n",
    "df['Revenue'] = df['Quantity'] * df['Price']\n",
    "\n",
    "top_qty_products = df.groupby('Description')['Quantity'].sum().nlargest(10)\n",
    "top_rev_products = df.groupby('Description')['Revenue'].sum().nlargest(10)\n",
    "\n",
    "print(\"\\n--- 5. Top 10 Best-Selling Products by Quantity ---\")\n",
    "print(top_qty_products)\n",
    "\n",
    "print(\"\\n--- 6. Top 10 Best-Selling Products by Revenue ---\")\n",
    "print(top_rev_products)\n",
    "\n",
    "# 5. SALES PERFORMANCE BY COUNTRY\n",
    "country_sales = df.groupby('Country')['Revenue'].sum().sort_values(ascending=False)\n",
    "print(\"\\n--- 7. Top 10 Revenue Generating Countries ---\")\n",
    "print(country_sales.head(10))\n",
    "\n",
    "# 6. PLOT REVENUE OVER TIME (MONTHLY TREND)\n",
    "df['InvoiceDate'] = pd.to_datetime(df['InvoiceDate'])\n",
    "df['YearMonth'] = df['InvoiceDate'].dt.to_period('M')\n",
    "monthly_revenue = df.groupby('YearMonth')['Revenue'].sum()\n",
    "\n",
    "plt.figure(figsize=(12, 5))\n",
    "monthly_revenue.plot(kind='line', marker='o', color='darkblue', linewidth=2)\n",
    "plt.title('Monthly Revenue Trend Analysis (2009-2011)', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Date (Year-Month)', fontsize=12)\n",
    "plt.ylabel('Total Revenue (£)', fontsize=12)\n",
    "plt.grid(True, linestyle='--', alpha=0.5)\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 7. CORRELATION HEATMAP\n",
    "plt.figure(figsize=(8, 5))\n",
    "numeric_corr = df[['Quantity', 'Price', 'Revenue']].corr()\n",
    "sns.heatmap(numeric_corr, annot=True, cmap='coolwarm', fmt=\".2f\", linewidths=0.5)\n",
    "plt.title('Correlation Matrix Heatmap', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "plt.figure(figsize=(14, 5))  # Fits brilliantly when Full Width Notebook is active\n",
    "plt.subplot(1, 2, 1)         # Left plot\n",
    "sns.boxplot(y=df['Quantity'], color='coral')\n",
    "plt.title('Outlier Detection: Quantity', fontsize=12, fontweight='bold')\n",
    "plt.ylabel('Quantity')\n",
    "\n",
    "plt.subplot(1, 2, 2)         # Right plot\n",
    "sns.boxplot(y=df['Price'], color='skyblue')\n",
    "plt.title('Outlier Detection: Price', fontsize=12, fontweight='bold')\n",
    "plt.ylabel('Price')\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
